# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net
JIRA_USERNAME=your@email.com
JIRA_API_TOKEN=...

# ── Git Platform ──────────────────────────────────────────────────────────────
# Set to "bitbucket" or "github"
GIT_PLATFORM=bitbucket

# Bitbucket Cloud (required if GIT_PLATFORM=bitbucket)
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_REPO_SLUG=your-repo
BITBUCKET_USERNAME=your-username
BITBUCKET_APP_PASSWORD=...

# GitHub (required if GIT_PLATFORM=github)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repo

# ── Target Repository ─────────────────────────────────────────────────────────
# The repo FORGE will clone, modify, and create PRs against
TARGET_REPO_URL=https://bitbucket.org/workspace/repo.git
TARGET_REPO_LOCAL_PATH=/tmp/forge_workspace
DEFAULT_BASE_BRANCH=main

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
# Comma-separated allowed origins for CORS (Streamlit default: 8501)
CORS_ORIGINS=http://localhost:8501

# ── Claude Model ──────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192

# ── Orchestrator ─────────────────────────────────────────────────────────────
# How many times the Coder can be re-run after reviewer feedback (beyond initial)
MAX_CODER_ITERATIONS=2
